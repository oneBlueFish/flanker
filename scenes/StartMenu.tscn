[gd_scene load_steps=10 format=3 uid="uid://start_menu"]

[ext_resource type="Script" path="res://scripts/MenuCamera.gd" id="1"]
[ext_resource type="Script" path="res://scripts/StartMenu.gd" id="2"]
[ext_resource type="Environment" path="res://assets/menu_environment.tres" id="3"]

[sub_resource type="StandardMaterial3D" id="Mat_title"]
albedo_color = Color(1.0, 0.3, 0.1, 1)
emission_enabled = true
emission = Color(1.0, 0.3, 0.1, 1)
emission_energy_multiplier = 1.5

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_normal"]
bg_color = Color(0.12, 0.12, 0.12, 0.9)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_hover"]
bg_color = Color(0.25, 0.25, 0.25, 0.95)

[sub_resource type="BoxMesh" id="BoxMesh_ground"]
size = Vector3(200, 1, 200)

[sub_resource type="StandardMaterial3D" id="Mat_ground"]
albedo_color = Color(0.05, 0.08, 0.05, 1)

[node name="StartMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
script = ExtResource("2")

[node name="MenuCamera" type="Camera3D" parent="."]
current = true
transform = Transform3D(1, 0, 0, 0, 0.5, 0.866, 0, -0.866, 0.5, 0, 60, 100)
fov = 90.0
script = ExtResource("1")
environment = ExtResource("3")

[node name="World3D" type="Node3D" parent="MenuCamera"]

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -180.0
offset_top = -120.0
offset_right = 180.0
offset_bottom = 180.0
grow_horizontal = 2
grow_vertical = 2
alignment = 1

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "FLANKERS"
horizontal_alignment = 1
add_theme_color_override("font_color", Color(1.0, 0.35, 0.1, 1))
add_theme_font_size_override("font_size", 100)

[node name="Spacer1" type="Control" parent="VBox"]
custom_minimum_size = Vector2(0, 30)
layout_mode = 2

[node name="HostButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(200, 50)
theme_normal_stylebox = SubResource("StyleBoxFlat_normal")
theme_hover_stylebox = SubResource("StyleBoxFlat_hover")
text = "Host Game"

[node name="JoinButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(200, 50)
theme_normal_stylebox = SubResource("StyleBoxFlat_normal")
theme_hover_stylebox = SubResource("StyleBoxFlat_hover")
text = "Join Game"

[node name="Spacer2" type="Control" parent="VBox"]
custom_minimum_size = Vector2(0, 15)
layout_mode = 2

[node name="LocalButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(200, 60)
theme_normal_stylebox = SubResource("StyleBoxFlat_normal")
theme_hover_stylebox = SubResource("StyleBoxFlat_hover")
text = "Local Play"

[node name="QuitButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(200, 50)
theme_normal_stylebox = SubResource("StyleBoxFlat_normal")
theme_hover_stylebox = SubResource("StyleBoxFlat_hover")
text = "Quit"

[node name="Spacer3" type="Control" parent="VBox"]
custom_minimum_size = Vector2(0, 40)
layout_mode = 2

[node name="Subtitle" type="Label" parent="VBox"]
layout_mode = 2
text = "Esc to quit"
horizontal_alignment = 1
add_theme_font_size_override = 18

[node name="JoinDialog" type="AcceptDialog" parent="."]
title = "Join Game"
size = Vector2i(400, 180)
unresizable = true
ok_button_text = "Join"
dialog_hide_on_ok = true
visible = false

[node name="VBoxContainer" type="VBoxContainer" parent="JoinDialog"]

[node name="AddressLabel" type="Label" parent="JoinDialog/VBoxContainer"]
layout_mode = 2
text = "Host IP Address:"
horizontal_alignment = 1

[node name="AddressEdit" type="LineEdit" parent="JoinDialog/VBoxContainer"]
layout_mode = 2
placeholder_text = "192.168.1.100"

[node name="PortLabel" type="Label" parent="JoinDialog/VBoxContainer"]
layout_mode = 2
text = "Port:"
horizontal_alignment = 1

[node name="PortEdit" type="LineEdit" parent="JoinDialog/VBoxContainer"]
layout_mode = 2
text = "8910"

[node name="NameLabel" type="Label" parent="JoinDialog/VBoxContainer"]
layout_mode = 2
text = "Your Name:"
horizontal_alignment = 1

[node name="NameEdit" type="LineEdit" parent="JoinDialog/VBoxContainer"]
layout_mode = 2
placeholder_text = "Player"

[node name="HostDialog" type="AcceptDialog" parent="."]
title = "Host Game"
size = Vector2i(400, 180)
unresizable = true
ok_button_text = "Host"
dialog_hide_on_ok = true
visible = false

[node name="VBoxContainer" type="VBoxContainer" parent="HostDialog"]

[node name="PortLabel" type="Label" parent="HostDialog/VBoxContainer"]
layout_mode = 2
text = "Port:"
horizontal_alignment = 1

[node name="PortEdit" type="LineEdit" parent="HostDialog/VBoxContainer"]
layout_mode = 2
text = "8910"

[node name="NameLabel" type="Label" parent="HostDialog/VBoxContainer"]
layout_mode = 2
text = "Your Name:"
horizontal_alignment = 1

[node name="NameEdit" type="LineEdit" parent="HostDialog/VBoxContainer"]
layout_mode = 2
placeholder_text = "Host"

[node name="ConnectionStatus" type="Label" parent="."]
visible = false
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -200.0
offset_top = -60.0
offset_right = 200.0
offset_bottom = -20.0
grow_horizontal = 2
grow_vertical = 0
horizontal_alignment = 1
vertical_alignment = 1

[connection signal="pressed" from="VBox/HostButton" to="." method="_on_host_pressed"]
[connection signal="pressed" from="VBox/JoinButton" to="." method="_on_join_pressed"]
[connection signal="pressed" from="VBox/LocalButton" to="." method="_on_local_pressed"]
[connection signal="pressed" from="VBox/QuitButton" to="." method="_on_quit_pressed"]
[connection signal="confirmed" from="JoinDialog" to="." method="_on_join_confirmed"]
[connection signal="confirmed" from="HostDialog" to="." method="_on_host_confirmed"]